[user]
	name = Robbie Diaz

# Work-specific overrides (email, Azure DevOps URLs, LFS, etc.)
# To make this conditional by directory, change to:
#   [includeIf "gitdir:~/work/"]
[include]
	path = ~/.gitconfig-work

[core]
	editor = nvim
	pager = delta
	excludesFile = ~/.gitignore_global

[init]
	defaultBranch = main

[pull]
	rebase = true

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[alias]
	dft = "!f() { GIT_EXTERNAL_DIFF=difft git diff $@; }; f"
	dftl = "!f() { GIT_EXTERNAL_DIFF=difft git log -p --ext-diff $@; }; f"
